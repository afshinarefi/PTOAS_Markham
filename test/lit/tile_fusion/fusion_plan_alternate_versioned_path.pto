// Guards exact dataflow-state search in FusionPlan. The early direct consumer
// has a low-scoring implementation version, so the planner should still explore
// the later branch from the seed and select that better version-compatible path.
//
// RUN: ptoas --pto-arch=a5 --pto-level=level2 --enable-op-fusion --emit-pto-ir %s --mlir-print-ir-after=pto-fusion-plan -o /dev/null 2>&1 | FileCheck %s

module {
  func.func @fusion_plan_alternate_versioned_path(
      %arg0: !pto.tile_buf<vec, 32x32xf32>,
      %arg1: !pto.tile_buf<vec, 32x32xf32>,
      %arg2: !pto.tile_buf<vec, 32x32xf32>,
      %arg3: !pto.tile_buf<vec, 32x32xf32>,
      %arg4: !pto.tile_buf<vec, 32x32xf32>,
      %arg5: !pto.tile_buf<vec, 32x32xf32>,
      %arg6: !pto.tile_buf<vec, 32x32xf32>) {
    %seed = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %bad = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %path0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %path1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %path2 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %path3 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tadd ins(%arg0, %arg1 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%seed : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d", postupdate = 0 : i64, tail = 0 : i64}]}
    pto.tmul ins(%seed, %arg6 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%bad : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 1 : i64, loop_depth = 2 : i64, name = "2d_tail_post", postupdate = 1 : i64, tail = 1 : i64}]}
    pto.tadd ins(%seed, %arg2 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%path0 : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d", postupdate = 0 : i64, tail = 0 : i64}]}
    pto.tadd ins(%path0, %arg3 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%path1 : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d", postupdate = 0 : i64, tail = 0 : i64}]}
    pto.tadd ins(%path1, %arg4 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%path2 : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d", postupdate = 0 : i64, tail = 0 : i64}]}
    pto.tadd ins(%path2, %arg5 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%path3 : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d", postupdate = 0 : i64, tail = 0 : i64}]}
    return
  }
}

// CHECK: // -----// IR Dump After FusionPlan (pto-fusion-plan) //----- //
// CHECK-LABEL: func.func @fusion_plan_alternate_versioned_path(
// CHECK: pto.tadd{{.*}}pto.fusion.group_id = 0 : i64{{.*}}pto.fusion.order = 0 : i64
// CHECK: pto.tmul ins(%{{.*}}, %arg6
// CHECK-NOT: pto.fusion.group_id
// CHECK: pto.tadd{{.*}}pto.fusion.group_id = 0 : i64{{.*}}pto.fusion.order = 1 : i64
// CHECK: pto.tadd{{.*}}pto.fusion.group_id = 0 : i64{{.*}}pto.fusion.order = 2 : i64
// CHECK: pto.tadd{{.*}}pto.fusion.group_id = 0 : i64{{.*}}pto.fusion.order = 3 : i64
// CHECK: pto.tadd{{.*}}pto.fusion.group_id = 0 : i64{{.*}}pto.fusion.order = 4 : i64
