// Guards FusionPlan's implementation-aware grouping. A group gets one common
// loop signature that uses NoPostUpdate. PostUpdate-only operations and
// operations with no common no-post-update signature split.
//
// RUN: ptoas --pto-arch=a5 --pto-level=level2 --enable-op-fusion --enable-fusion-version-selection --emit-pto-ir %s --mlir-print-ir-after=pto-fusion-plan-version-selection -o /dev/null 2>&1 | FileCheck --implicit-check-not="versions =" %s

module {
  func.func @select_common_implementation(
      %arg0: !pto.tile_buf<vec, 32x32xf32>) {
    %tmp0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tadd ins(%arg0, %arg0 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32>) {versions = [{id = 1 : i64, name = "tadd_1d", loop_depth = 1 : i64, vf_impl_kind = "NoPostUpdate", tail = "no_tail"}, {id = 2 : i64, name = "tadd_2d", loop_depth = 2 : i64, vf_impl_kind = "NoPostUpdate", tail = "has_tail"}, {id = 3 : i64, name = "tadd_2d_post_update", loop_depth = 2 : i64, vf_impl_kind = "PostUpdate", tail = "has_tail"}]}
    pto.tmul ins(%tmp0, %arg0 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32>) {versions = [{id = 7 : i64, name = "tmul_1d", loop_depth = 1 : i64, vf_impl_kind = "NoPostUpdate", tail = "no_tail"}, {id = 8 : i64, name = "tmul_2d", loop_depth = 2 : i64, vf_impl_kind = "NoPostUpdate", tail = "has_tail"}]}
    return
  }

  func.func @reject_incompatible_implementations(
      %arg0: !pto.tile_buf<vec, 32x32xf32>) {
    %tmp0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tadd ins(%arg0, %arg0 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32>) {versions = [{id = 1 : i64, name = "tadd_post_update", loop_depth = 1 : i64, vf_impl_kind = "PostUpdate", tail = "has_tail"}]}
    pto.tmul ins(%tmp0, %arg0 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32>) {versions = [{id = 2 : i64, name = "tmul_2d", loop_depth = 2 : i64, vf_impl_kind = "NoPostUpdate", tail = "no_tail"}]}
    return
  }

  func.func @reject_post_update_only(
      %arg0: !pto.tile_buf<vec, 32x32xf32>) {
    %tmp0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tadd ins(%arg0, %arg0 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32>) {versions = [{id = 1 : i64, name = "tadd_2d_post_update", loop_depth = 2 : i64, vf_impl_kind = "PostUpdate", tail = "has_tail"}]}
    pto.tmul ins(%tmp0, %arg0 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32>) {versions = [{id = 2 : i64, name = "tmul_2d_post_update", loop_depth = 2 : i64, vf_impl_kind = "PostUpdate", tail = "no_tail"}]}
    return
  }
}

// CHECK: // -----// IR Dump After FusionPlanVersionSelection (pto-fusion-plan-version-selection) //----- //
// CHECK-DAG: pto.tadd{{.*}}{pto.fusion.group_id = 0 : i64{{.*}}version_name = "tadd_1d"
// CHECK-DAG: pto.tmul{{.*}}{pto.fusion.group_id = 0 : i64{{.*}}version_name = "tmul_1d"
// CHECK-DAG: pto.tadd{{.*}}{version_name = "tadd_post_update"}
// CHECK-DAG: pto.tmul{{.*}}{version_name = "tmul_2d"}
// CHECK-DAG: pto.tadd{{.*}}{version_name = "tadd_2d_post_update"}
// CHECK-DAG: pto.tmul{{.*}}{version_name = "tmul_2d_post_update"}
