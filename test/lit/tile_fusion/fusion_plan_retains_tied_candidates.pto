// FusionPlan narrows each selected group member's candidate list to versions
// participating in a best-scoring assignment. It keeps both equally scored 1D
// candidates for later version selection and removes the lower-scoring 2D
// tail/postupdate candidate.
//
// RUN: ptoas --pto-arch=a5 --pto-level=level2 --enable-op-fusion --emit-pto-ir %s --mlir-print-ir-after=pto-fusion-plan -o /dev/null 2>&1 | FileCheck %s

module {
  func.func @fusion_plan_retains_tied_candidates(
      %arg0: !pto.tile_buf<vec, 32x32xf32>,
      %arg1: !pto.tile_buf<vec, 32x32xf32>,
      %arg2: !pto.tile_buf<vec, 32x32xf32>) {
    %tmp0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tadd ins(%arg0, %arg1 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d_a", postupdate = 0 : i64, tail = 0 : i64}, {id = 1 : i64, loop_depth = 1 : i64, name = "1d_b", postupdate = 0 : i64, tail = 0 : i64}, {id = 2 : i64, loop_depth = 2 : i64, name = "2d_tail_post", postupdate = 1 : i64, tail = 1 : i64}]}
    pto.tadd ins(%tmp0, %arg2 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32>) {candidates = [{id = 0 : i64, loop_depth = 1 : i64, name = "1d_a", postupdate = 0 : i64, tail = 0 : i64}, {id = 1 : i64, loop_depth = 1 : i64, name = "1d_b", postupdate = 0 : i64, tail = 0 : i64}, {id = 2 : i64, loop_depth = 2 : i64, name = "2d_tail_post", postupdate = 1 : i64, tail = 1 : i64}]}
    return
  }
}

// CHECK: // -----// IR Dump After FusionPlan (pto-fusion-plan) //----- //
// CHECK-LABEL: func.func @fusion_plan_retains_tied_candidates(
// CHECK: pto.tadd
// CHECK-SAME: candidates = [
// CHECK-SAME: id = 0 : i64
// CHECK-SAME: id = 1 : i64
// CHECK-NOT: id = 2 : i64
// CHECK: pto.tadd
// CHECK-SAME: candidates = [
// CHECK-SAME: id = 0 : i64
// CHECK-SAME: id = 1 : i64
// CHECK-NOT: id = 2 : i64
// CHECK: return
