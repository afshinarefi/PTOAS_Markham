module attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @pointwise_diamond_fusion() {
    %a = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %b = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %c = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %d = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %e = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %f = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp0 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp2 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp3 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp4 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %tmp5 = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>
    %out = pto.alloc_tile : !pto.tile_buf<vec, 32x32xf32>

    pto.tmax ins(%a, %b : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp0 : !pto.tile_buf<vec, 32x32xf32>)
    pto.tsub ins(%tmp0, %c : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp1 : !pto.tile_buf<vec, 32x32xf32>)
    pto.tsub ins(%tmp0, %d : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp2 : !pto.tile_buf<vec, 32x32xf32>)
    pto.texp ins(%tmp1 : !pto.tile_buf<vec, 32x32xf32>) outs(%tmp3 : !pto.tile_buf<vec, 32x32xf32>)
    pto.texp ins(%tmp2 : !pto.tile_buf<vec, 32x32xf32>) outs(%tmp4 : !pto.tile_buf<vec, 32x32xf32>)
    pto.tmul ins(%tmp3, %e : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp5 : !pto.tile_buf<vec, 32x32xf32>)
    pto.tmul ins(%tmp4, %f : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%tmp2 : !pto.tile_buf<vec, 32x32xf32>)
    pto.tadd ins(%tmp5, %tmp2 : !pto.tile_buf<vec, 32x32xf32>, !pto.tile_buf<vec, 32x32xf32>) outs(%out : !pto.tile_buf<vec, 32x32xf32>)
    return
  }
}
