// Minimal keep/resume probe for non-immediate 32-bit and 64-bit swaps.
//
// stage0 puts lane-dependent values in 32-bit slots 0/1 and 64-bit slots 2/4:
//   slot 0 / TPER4 = tid + 100
//   slot 1 / TPER5 = tid + 200
//   slot 2 / TPERL3 / R6:R7 = 0x1122334400000000 + tid
//   slot 4 / TPERL4 / R8:R9 = 0x5566778800000000 + tid
//
// stage1 resumes both values and keeps them in the opposite slots.  The
// resulting fixed-register assignment is intentionally a parallel copy:
//   TPER4 <- old TPER5, TPER5 <- old TPER4
//   TPERL3 <- old TPERL4
//   TPERL4 <- old TPERL3
//
// stage2 resumes the swapped values and writes the i32 and i64 pairs to GM.
module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @simt_keep_resume_register_swap_kernel(%arg0: !pto.ptr<i32, gm>, %arg1: !pto.ptr<i64, gm>) attributes {pto.aicore} {
    %dim_z = arith.constant 1 : i32
    %dim_y = arith.constant 1 : i32
    %dim_x = arith.constant 32 : i32
    pto.store_vfsimt_info %dim_z, %dim_y, %dim_x : i32, i32, i32

    func.call @stage0() : () -> ()
    func.call @stage1() : () -> ()
    func.call @stage2(%arg0, %arg1) : (!pto.ptr<i32, gm>, !pto.ptr<i64, gm>) -> ()
    return
  }

  func.func @stage0() attributes {pto.simt_entry} {
    %tid = pto.get_tid_x : i32
    %tid64 = arith.extui %tid : i32 to i64
    %c100 = arith.constant 100 : i32
    %c200 = arith.constant 200 : i32
    %base64_a = arith.constant 1234605615003729920 : i64
    %base64_b = arith.constant 6153737366847619072 : i64
    %a = arith.addi %tid, %c100 : i32
    %b = arith.addi %tid, %c200 : i32
    %wide_a = arith.addi %tid64, %base64_a : i64
    %wide_b = arith.addi %tid64, %base64_b : i64
    pto.keep %a {slot = 0 : i64} : i32
    pto.keep %b {slot = 1 : i64} : i32
    pto.keep %wide_a {slot = 2 : i64} : i64
    pto.keep %wide_b {slot = 4 : i64} : i64
    return
  }

  func.func @stage1() attributes {pto.simt_entry} {
    %a = pto.resume {slot = 0 : i64} : i32
    %b = pto.resume {slot = 1 : i64} : i32
    %wide_a = pto.resume {slot = 2 : i64} : i64
    %wide_b = pto.resume {slot = 4 : i64} : i64
    // Deliberately reverse the destinations to force a parallel copy.
    pto.keep %b {slot = 0 : i64} : i32
    pto.keep %a {slot = 1 : i64} : i32
    pto.keep %wide_b {slot = 2 : i64} : i64
    pto.keep %wide_a {slot = 4 : i64} : i64
    return
  }

  func.func @stage2(%gm32: !pto.ptr<i32, gm>, %gm64: !pto.ptr<i64, gm>) attributes {pto.simt_entry} {
    %swapped0 = pto.resume {slot = 0 : i64} : i32
    %swapped1 = pto.resume {slot = 1 : i64} : i32
    %swapped64_0 = pto.resume {slot = 2 : i64} : i64
    %swapped64_1 = pto.resume {slot = 4 : i64} : i64
    %tid = pto.get_tid_x : i32
    %c1 = arith.constant 1 : i32
    %c2 = arith.constant 2 : i32
    %idx0 = arith.muli %tid, %c2 : i32
    %idx1 = arith.addi %idx0, %c1 : i32
    %idx0_i = arith.index_castui %idx0 : i32 to index
    %idx1_i = arith.index_castui %idx1 : i32 to index
    pto.store %swapped0, %gm32[%idx0_i] : !pto.ptr<i32, gm>, i32
    pto.store %swapped1, %gm32[%idx1_i] : !pto.ptr<i32, gm>, i32
    pto.store %swapped64_0, %gm64[%idx0_i] : !pto.ptr<i64, gm>, i64
    pto.store %swapped64_1, %gm64[%idx1_i] : !pto.ptr<i64, gm>, i64
    return
  }
}
